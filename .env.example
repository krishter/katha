# Copy to .env and fill in values — never commit .env
DATABASE_URL=postgresql+asyncpg://katha:katha@localhost:5432/katha
ENVIRONMENT=development
LOG_LEVEL=info

# Phase 1
SARVAM_API_KEY=your_sarvam_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Phase 4 — WhatsApp / Twilio
WHATSAPP_ADAPTER=stub                          # "stub" for dev/test, "twilio" for real sends
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # sandbox; replace with production number later
WEBHOOK_VERIFY_TOKEN=katha-webhook-verify

# Phase 4 — WhatsApp message template SIDs (filled in after Meta approval)
TWILIO_TEMPLATE_SESSION_OPEN=
TWILIO_TEMPLATE_FOLLOWUP=
TWILIO_TEMPLATE_MEMORY_CARD=

# Phase 4 — AWS S3 (Mumbai — DPDP Act data residency)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=katha-media
AWS_S3_REGION=ap-south-1
